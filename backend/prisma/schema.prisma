generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======== TABLA PRINCIPAL ========
model Documento {
  id           String   @id @default(uuid())
  titulo       String
  descripcion  String?  
  fecha        String
  gestion      String
  categoria    String
  enlaceVideo  String?
  etiquetas    String[] 
  detalles     Json?    // Aquí entran los campos dinámicos (Ciclo, Asistentes, etc.)
  fechaSubida  DateTime @default(now())

  archivos     ArchivoAdjunto[]
}

// ======== TABLA DE ARCHIVOS ========
model ArchivoAdjunto {
  id             String    @id @default(uuid())
  ruta           String
  nombreOriginal String
  pesoBytes      Int
  tipo           String    

  documentoId    String
  documento      Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
}